{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TouchFish",
  "version": "0.1.0",
  "identifier": "com.ushi.touchfish",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TouchFish",
        "width": 360,
        "height": 520,
        "minWidth": 280,
        "minHeight": 200,
        "decorations": true,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": true,
        "visible": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
